# --- Secrets and Credentials ---
# Never upload your real passwords to GitHub
.env
.env.local

# --- Dependencies ---
# These are huge and can be reinstalled using 'npm install'
node_modules/

# --- Build Output ---
# If you compile your TS to JS, ignore the generated files
dist/
out/
*.js
# Note: Remove *.js if you have actual JS files you WANT to keep 
# but usually, in a TS project, .js files are just "build noise".

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE/OS Specific ---
.vscode/
.DS_Store
Thumbs.db